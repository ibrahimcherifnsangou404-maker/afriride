# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/afriride
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=afriride

# JWT
JWT_SECRET=votre_secret_jwt_tres_securise
JWT_EXPIRE=7d

# Email (Gmail - exemple)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=votre_email@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_app_gmail
EMAIL_FROM=noreply@afriride.com

# SMS Twilio (Optionnel)
TWILIO_ACCOUNT_SID=votre_account_sid
TWILIO_AUTH_TOKEN=votre_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Optionnel - notifications push)
FIREBASE_CONFIG={"type":"service_account","project_id":"..."}

# Application
PORT=5000
NODE_ENV=development
